### ========================================
### HEALTH
### ========================================

### Health check
GET {{baseUrl}}/health


### ========================================
### AUTH
### ========================================

### Register main user
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### Login main user
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### Register coach
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "{{coachEmail}}",
  "password": "{{coachPassword}}"
}

### Login coach
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{coachEmail}}",
  "password": "{{coachPassword}}"
}

### Register student
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "{{studentEmail}}",
  "password": "{{studentPassword}}"
}

### Login student
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{studentEmail}}",
  "password": "{{studentPassword}}"
}

### Make user coach
POST {{baseUrl}}/internal/admin/users/{{userIdFromCoach}}/make-coach
Authorization: Bearer {{jwt}}

### ========================================
### RIOT IMPORT
### ========================================

### Riot account lookup
GET {{baseUrl}}/internal/riot/Niklas409/0409

### Riot recent match ids
GET {{baseUrl}}/internal/riot/matches/Niklas409/0409

### Riot recent stats
GET {{baseUrl}}/internal/riot/recent-stats/Niklas409/0409

### Import recent matches
POST {{baseUrl}}/internal/riot/import/Niklas409/0409
Authorization: Bearer {{jwt}}

### Import recent matches with count
POST {{baseUrl}}/internal/riot/import/Niklas409/0409?count=3
Authorization: Bearer {{jwt}}


### ========================================
### MATCHES
### ========================================

### Get all matches
GET {{baseUrl}}/matches
Authorization: Bearer {{jwt}}

### Get match details by matchId
GET {{baseUrl}}/matches/{{matchId}}
Authorization: Bearer {{jwt}}


### ========================================
### COACH - STUDENTS
### ========================================

### Assign student to coach
POST {{baseUrl}}/coach/students/{{studentId}}
Authorization: Bearer {{coachJwt}}

### Get students for coach
GET {{baseUrl}}/coach/students
Authorization: Bearer {{coachJwt}}

### Remove student from coach
DELETE {{baseUrl}}/coach/students/{{studentId}}
Authorization: Bearer {{coachJwt}}


### ========================================
### MATCH NOTES
### ========================================

### Create note for match
POST {{baseUrl}}/coach/matches/{{matchId}}/notes
Authorization: Bearer {{coachJwt}}
Content-Type: application/json

{
  "studentId": {{studentId}},
  "content": "Wave zu früh gepusht – Jungle Gank möglich."
}

### Get notes for match
GET {{baseUrl}}/coach/matches/{{matchId}}/notes?studentId={{studentId}}
Authorization: Bearer {{coachJwt}}

### Update note
PUT {{baseUrl}}/coach/notes/1
Authorization: Bearer {{coachJwt}}
Content-Type: application/json

{
  "content": "Wave zu früh gepusht und Recall Timing war ebenfalls schlecht."
}

### Delete note
DELETE {{baseUrl}}/coach/notes/1
Authorization: Bearer {{coachJwt}}


### ========================================
### TASKS
### ========================================

### Create task for student
POST {{baseUrl}}/coach/students/{{studentId}}/tasks
Authorization: Bearer {{coachJwt}}
Content-Type: application/json

{
  "description": "3 Games lang nur auf Vision achten"
}

### Get tasks for student
GET {{baseUrl}}/coach/students/{{studentId}}/tasks
Authorization: Bearer {{coachJwt}}

### Update task
PUT {{baseUrl}}/coach/tasks/1
Authorization: Bearer {{coachJwt}}
Content-Type: application/json

{
  "description": "5 Games Vision + Wave Management üben"
}

### Complete own task
PATCH {{baseUrl}}/tasks/1/complete
Authorization: Bearer {{studentJwt}}

### Uncomplete own task
PATCH {{baseUrl}}/tasks/1/uncomplete
Authorization: Bearer {{studentJwt}}

### Delete task
DELETE {{baseUrl}}/coach/tasks/1
Authorization: Bearer {{coachJwt}}