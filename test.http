### ========================================
### HEALTH
### ========================================

### Health check
GET {{baseUrl}}/health


### ========================================
### AUTH - REGISTER
### ========================================

### Register user
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### Register - duplicate email
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### Register - invalid email
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "not-an-email",
  "password": "123456"
}

### Register - blank password
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "newuser@test.com",
  "password": ""
}

### Register - blank email
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "",
  "password": "123456"
}


### ========================================
### AUTH - LOGIN
### ========================================

### Login success
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### Login - wrong password
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "wrongpassword"
}

### Login - user does not exist
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "doesnotexist@test.com",
  "password": "123456"
}


### ========================================
### PROTECTED ENDPOINTS - WITHOUT TOKEN
### ========================================

### Get all matches without token -> should be 401
GET {{baseUrl}}/matches

### Get player stats without token -> should be 401
GET {{baseUrl}}/players/{{playerId}}/stats


### ========================================
### PLAYER
### ========================================

### Create player
POST {{baseUrl}}/players
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "playerId": "{{playerId}}",
  "name": "Niklas",
  "region": "EUW"
}

### Create player - validation error
POST {{baseUrl}}/players
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "playerId": "",
  "name": "",
  "region": ""
}


### ========================================
### MATCHES
### ========================================

### Create first match
POST {{baseUrl}}/matches
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "playerId": "{{playerId}}",
  "champion": "Ahri",
  "win": true,
  "kills": 10,
  "deaths": 2,
  "assists": 6,
  "playedAt": "2026-03-01T21:30:00Z"
}

### Create second match
POST {{baseUrl}}/matches
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "playerId": "{{playerId}}",
  "champion": "Vayne",
  "win": true,
  "kills": 12,
  "deaths": 1,
  "assists": 3,
  "playedAt": "2026-03-01T22:15:00Z"
}

### Create match - non-existing player
POST {{baseUrl}}/matches
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "playerId": "does-not-exist",
  "champion": "Darius",
  "win": false,
  "kills": 2,
  "deaths": 10,
  "assists": 1,
  "playedAt": "2026-03-01T23:00:00Z"
}


### ========================================
### QUERIES
### ========================================

### Get all matches
GET {{baseUrl}}/matches
Authorization: Bearer {{jwt}}

### Get stats for existing player
GET {{baseUrl}}/players/{{playerId}}/stats
Authorization: Bearer {{jwt}}

### Get stats for non-existing player
GET {{baseUrl}}/players/does-not-exist/stats
Authorization: Bearer {{jwt}}