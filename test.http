### ========================================
### HEALTH
### ========================================

### Health check
GET {{baseUrl}}/health


### ========================================
### AUTH - REGISTER
### ========================================

### Register user
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### Register - duplicate email
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### Register - invalid email
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "not-an-email",
  "password": "123456"
}

### Register - blank password
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "newuser@test.com",
  "password": ""
}

### Register - blank email
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "",
  "password": "123456"
}


### ========================================
### AUTH - LOGIN
### ========================================

### Login success
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### Login - wrong password
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "wrongpassword"
}

### Login - user does not exist
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "doesnotexist@test.com",
  "password": "123456"
}


### ========================================
### PROTECTED ENDPOINTS - WITHOUT TOKEN
### ========================================

### Get all matches without token -> should be 401
GET {{baseUrl}}/matches

### Get player stats without token -> should be 401
GET {{baseUrl}}/players/{{playerId}}/stats


### ========================================
### PLAYER
### ========================================

### Create player
POST {{baseUrl}}/players
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "playerId": "{{playerId}}",
  "name": "Niklas",
  "region": "EUW"
}

### Create player - validation error
POST {{baseUrl}}/players
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "playerId": "",
  "name": "",
  "region": ""
}


### ========================================
### MATCHES
### ========================================

### Create first match
POST {{baseUrl}}/matches
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "playerId": "{{playerId}}",
  "champion": "Ahri",
  "win": true,
  "kills": 10,
  "deaths": 2,
  "assists": 6,
  "playedAt": "2026-03-01T21:30:00Z"
}

### Create second match
POST {{baseUrl}}/matches
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "playerId": "{{playerId}}",
  "champion": "Vayne",
  "win": true,
  "kills": 12,
  "deaths": 1,
  "assists": 3,
  "playedAt": "2026-03-01T22:15:00Z"
}

### Create match - non-existing player
POST {{baseUrl}}/matches
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "playerId": "does-not-exist",
  "champion": "Darius",
  "win": false,
  "kills": 2,
  "deaths": 10,
  "assists": 1,
  "playedAt": "2026-03-01T23:00:00Z"
}


### ========================================
### QUERIES
### ========================================

### Get all matches
GET {{baseUrl}}/matches
Authorization: Bearer {{jwt}}

### Get stats for existing player
GET {{baseUrl}}/players/{{playerId}}/stats
Authorization: Bearer {{jwt}}

### Get stats for non-existing player
GET {{baseUrl}}/players/does-not-exist/stats
Authorization: Bearer {{jwt}}

### ========================================
### RIOT IMPORT / INTERNAL
### ========================================

### Riot account lookup
GET {{baseUrl}}/internal/riot/Niklas409/0409

### Riot recent match ids
GET {{baseUrl}}/internal/riot/matches/Niklas409/0409

### Riot recent stats
GET {{baseUrl}}/internal/riot/recent-stats/Niklas409/0409

### Riot import recent matches
POST {{baseUrl}}/internal/riot/import/Niklas409/0409

### Riot import recent matches with count
POST {{baseUrl}}/internal/riot/import/Niklas409/0409?count=3

### ========================================
### COACH RELATION
### ========================================

### Register coach test user
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "{{coachEmail}}",
  "password": "{{coachPassword}}"
}

### Register student test user
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "{{studentEmail}}",
  "password": "{{studentPassword}}"
}

### Login coach
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{coachEmail}}",
  "password": "{{coachPassword}}"
}

### Login student
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{studentEmail}}",
  "password": "{{studentPassword}}"
}

### Assign student to coach -> should be 200/201 with COACH token
POST {{baseUrl}}/coach/students/{{studentId}}
Authorization: Bearer {{coachJwt}}

### Assign same student again -> should fail because relation already exists
POST {{baseUrl}}/coach/students/{{studentId}}
Authorization: Bearer {{coachJwt}}

### Assign student with normal USER token -> should be 403
POST {{baseUrl}}/coach/students/{{studentId}}
Authorization: Bearer {{studentJwt}}

### Assign non-existing student -> should be 404
POST {{baseUrl}}/coach/students/999999
Authorization: Bearer {{coachJwt}}

### Coach assigns himself as student -> should fail
POST {{baseUrl}}/coach/students/3
Authorization: Bearer {{coachJwt}}

### ========================================
### COACH - STUDENTS
### ========================================

### Get students for coach -> should return list of assigned students
GET {{baseUrl}}/coach/students
Authorization: Bearer {{coachJwt}}

### Get students for coach -> should return empty list if no students assigned
GET {{baseUrl}}/coach/students
Authorization: Bearer {{coachJwt}}

### Get students without token -> should be 401
GET {{baseUrl}}/coach/students

### Get students with normal USER token -> should be 403
GET {{baseUrl}}/coach/students
Authorization: Bearer {{studentJwt}}

### ========================================
### COACH - REMOVE STUDENT
### ========================================

### Remove assigned student from coach -> should succeed
DELETE {{baseUrl}}/coach/students/{{studentId}}
Authorization: Bearer {{coachJwt}}

### Remove same student again -> should be 404 because relation no longer exists
DELETE {{baseUrl}}/coach/students/{{studentId}}
Authorization: Bearer {{coachJwt}}

### Remove student without token -> should be 401
DELETE {{baseUrl}}/coach/students/{{studentId}}

### Remove student with normal USER token -> should be 403
DELETE {{baseUrl}}/coach/students/{{studentId}}
Authorization: Bearer {{studentJwt}}

### Remove non-existing student -> should be 404
DELETE {{baseUrl}}/coach/students/999999
Authorization: Bearer {{coachJwt}}

### ========================================
### MATCH NOTES
### ========================================

### Create note for match
POST {{baseUrl}}/coach/matches/{{matchId}}/notes
Authorization: Bearer {{coachJwt}}
Content-Type: application/json

{
  "studentId": {{studentId}},
  "content": "Wave zu früh gepusht – Jungle Gank möglich."
}

### Create note with USER token -> should be 403
POST {{baseUrl}}/coach/matches/{{matchId}}/notes
Authorization: Bearer {{studentJwt}}
Content-Type: application/json

{
  "studentId": {{studentId}},
  "content": "Test"
}